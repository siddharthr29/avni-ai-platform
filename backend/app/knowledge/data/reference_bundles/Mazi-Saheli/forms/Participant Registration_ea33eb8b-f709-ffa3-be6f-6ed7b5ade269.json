  "decisionRule" : "",
  "visitScheduleRule" : "",
  "validationRule" : "'use strict';\n({params, imports}) => {\n  const entity = params.entity;\n  const validationResults = [];\n  const contactNumber = entity.getObservationValue('Contact Number');\n  if (contactNumber) {\n    const s = String(Math.round(contactNumber));\n    if (s.length !== 10 || !/^[6-9]/.test(s)) {\n      validationResults.push(imports.common.createValidationError('Contact Number must be 10 digits starting with 6-9'));\n    }\n  }\n  return validationResults;\n};",
