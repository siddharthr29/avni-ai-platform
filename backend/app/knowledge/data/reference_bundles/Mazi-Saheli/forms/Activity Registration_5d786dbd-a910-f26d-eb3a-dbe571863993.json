  "validationRule" : "'use strict';\n({params, imports}) => {\n  const entity = params.entity;\n  const validationResults = [];\n  const startDate = entity.getObservationValue('Start Date of Event');\n  const endDate = entity.getObservationValue('End Date of Event');\n  if (startDate && endDate && new Date(endDate) < new Date(startDate)) {\n    validationResults.push(imports.common.createValidationError('End Date must be on or after Start Date'));\n  }\n  const contactNo = entity.getObservationValue('Contact No');\n  if (contactNo) {\n    const s = String(Math.round(contactNo));\n    if (s.length !== 10 || !/^[6-9]/.test(s)) {\n      validationResults.push(imports.common.createValidationError('Contact No must be 10 digits starting with 6-9'));\n    }\n  }\n  return validationResults;\n};",
