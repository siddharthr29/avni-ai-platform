  "query" : "'use strict';\n({params, imports}) => {\n  const cutoff = imports.moment().subtract(3, 'days').startOf('day').toDate();\n  return params.db.objects('Individual').filtered('voided = false AND subjectType.name = \"Participant\"').filter(p => p.nonVoidedEncounters().some(e => e.encounterType.name === 'Assessment & Distribution' && e.encounterDateTime != null && new Date(e.encounterDateTime) >= cutoff));\n};",
  "description" : "Participants with Assessment & Distribution completed in last 3 days",
