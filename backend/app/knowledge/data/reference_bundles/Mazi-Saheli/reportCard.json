  "query" : "'use strict';\n({params, imports}) => {\n  return params.db.objects('Individual').filtered('voided = false AND subjectType.name = \"Participant\"').filter(p => p.nonVoidedEncounters().some(e => e.encounterType.name === 'Assessment & Distribution' && e.encounterDateTime != null));\n};",
