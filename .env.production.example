# =============================================================================
# Avni AI Platform — Production Environment Variables
# Copy this file to .env and fill in all required values.
#
# Usage:
#   cp .env.production.example .env
#   # Edit .env with your production secrets
#   docker compose -f docker-compose.prod.yml up -d
# =============================================================================

# ---------------------------------------------------------------------------
# DATABASE (required)
# ---------------------------------------------------------------------------
# Strong password for PostgreSQL. Generate with: openssl rand -base64 32
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ---------------------------------------------------------------------------
# API SECURITY (required)
# ---------------------------------------------------------------------------
# Comma-separated API keys for authenticating requests.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=key1,key2

# Rate limit: max requests per minute per client
RATE_LIMIT_RPM=30

# ---------------------------------------------------------------------------
# LLM PROVIDER
# ---------------------------------------------------------------------------
# Options: openai (primary), ollama (self-hosted fallback)
# Groq, Cerebras, Gemini are available via BYOK (users bring their own key)
LLM_PROVIDER=openai

# Ollama (default, self-hosted — no API key needed)
# CRITICAL: Set these on the Ollama HOST machine for concurrency:
#   export OLLAMA_NUM_PARALLEL=8
#   export OLLAMA_MAX_LOADED_MODELS=2
#   ollama serve
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=avni-coder

# LLM concurrency limit (max simultaneous LLM requests — prevents queue explosion)
LLM_CONCURRENCY_LIMIT=8

# Cerebras (free tier — ultra-fast inference, ~2000 tok/s)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

# Groq (free tier fallback)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (free tier — Google AI, vision support)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Anthropic (production paid tier)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# General LLM settings
MAX_TOKENS=4096
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ---------------------------------------------------------------------------
# AVNI PLATFORM
# ---------------------------------------------------------------------------
AVNI_BASE_URL=https://app.avniproject.org
AVNI_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# MCP SERVER
# ---------------------------------------------------------------------------
MCP_SERVER_URL=http://host.docker.internal:8023

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated allowed origins for CORS
CORS_ORIGINS=https://ai.avniproject.org

# ---------------------------------------------------------------------------
# NGINX / SSL
# ---------------------------------------------------------------------------
# Ports exposed on the host
HTTP_PORT=80
HTTPS_PORT=443

# Domain for SSL certificate (used by certbot)
DOMAIN=ai.avniproject.org

# ---------------------------------------------------------------------------
# MONITORING
# ---------------------------------------------------------------------------
# Grafana admin password. Generate with: openssl rand -base64 16
GRAFANA_PASSWORD=CHANGE_ME
GRAFANA_USER=admin
GRAFANA_PORT=3001
GRAFANA_ROOT_URL=https://ai.avniproject.org:3001

# ---------------------------------------------------------------------------
# BACKUPS
# ---------------------------------------------------------------------------
# S3 bucket for off-site backup storage (optional)
S3_BUCKET=
S3_PREFIX=avni-ai/backups

# ---------------------------------------------------------------------------
# NOTIFICATIONS (optional)
# ---------------------------------------------------------------------------
# Slack webhook for deploy/alert notifications
SLACK_WEBHOOK_URL=

# SMTP settings for AlertManager email notifications
SMTP_SMARTHOST=smtp.example.com:587
SMTP_FROM=alertmanager@avniproject.org
SMTP_AUTH_USERNAME=alertmanager@avniproject.org
SMTP_PASSWORD=
ALERT_EMAIL_TO=ops-team@avniproject.org

# ---------------------------------------------------------------------------
# REDIS (for rate limiting across workers)
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# Database connection pool per worker (8 workers x 20 max = 160 connections)
DB_POOL_MIN=5
DB_POOL_MAX=20

# ---------------------------------------------------------------------------
# JWT AUTH (required for production)
# ---------------------------------------------------------------------------
# CRITICAL: Generate a strong secret: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING

# ---------------------------------------------------------------------------
# ERROR TRACKING
# ---------------------------------------------------------------------------
# Sentry DSN for error tracking (optional but recommended)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=production
