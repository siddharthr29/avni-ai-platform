# Avni AI Platform Configuration
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql://avni:avni_ai_2026@localhost:5432/avni_ai

# LLM Provider: ollama | cerebras | groq | gemini | anthropic
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=avni-coder

# Optional: API keys for LLM providers (only needed if using that provider)
GROQ_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Avni Server
AVNI_BASE_URL=https://app.avniproject.org

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Security (empty = dev mode, no auth required)
API_KEYS=
RATE_LIMIT_RPM=60
